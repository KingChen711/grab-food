{
  "name": "@grab/nestjs-common",
  "version": "0.0.1",
  "private": true,
  "description": "Shared NestJS building blocks — filters, interceptors, guards, decorators",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "rxjs": "^7.8.1",
    "@grab/types": "workspace:*"
  },
  "devDependencies": {
    "@grab/config": "workspace:*",
    "@types/express": "^5.0.0",
    "typescript": "^5.8.2",
    "rimraf": "^6.0.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "rxjs": "^7.8.1"
  }
}
