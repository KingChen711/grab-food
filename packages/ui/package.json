{
  "name": "@grab/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shared UI component library based on Shadcn/ui for the Grab platform",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
